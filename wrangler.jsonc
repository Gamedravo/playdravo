{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gamedravo",
  "compatibility_date": "2026-06-06",
  "routes": [
    {
      "pattern": "gamedravo.com",
      "custom_domain": true
    },
    {
      "pattern": "www.gamedravo.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
