{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "tsx scripts/generate-sitemap.ts && vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:static": "tsx scripts/generate-sitemap.ts && vite build",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "import:catalog": "tsx scripts/import-onlinegames-catalog.ts",
    "import:catalog:audit": "tsx scripts/import-onlinegames-catalog.ts --audit-only",
    "import:external": "tsx scripts/import-external-games.ts",
    "import:external:apply": "tsx scripts/import-external-games.ts --apply",
    "health:games": "tsx scripts/game-health-check.ts",
    "health:games:apply": "tsx scripts/game-health-check.ts --apply",
    "audit:mobile": "tsx scripts/audit-mobile-gameplay.ts",
    "audit:thumbnails": "tsx scripts/audit-thumbnails.ts",
    "audit:thumbnails:apply": "tsx scripts/audit-thumbnails.ts -- --apply",
    "audit:ads": "tsx scripts/audit-ads-injection.ts",
    "audit:production": "node scripts/production-health-audit.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "express": "^4.22.2",
    "firebase": "^12.14.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.16.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^6.4.3"
  }
}
