{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "echo \"pre-built\"",
    "build:full": "tsx scripts/generate-sitemap.ts && vite build",
    "build:server": "tsx scripts/generate-sitemap.ts && vite build && esbuild server.ts --bundle --platform=node --format=cjs --external:pg-native --sourcemap --outfile=dist/server.cjs",
    "build:static": "tsx scripts/generate-sitemap.ts && vite build",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "import:catalog": "tsx scripts/import-onlinegames-catalog.ts",
    "import:catalog:audit": "tsx scripts/import-onlinegames-catalog.ts --audit-only",
    "import:external": "tsx scripts/import-external-games.ts",
    "import:external:apply": "tsx scripts/import-external-games.ts --apply",
    "health:games": "tsx scripts/game-health-check.ts",
    "health:games:apply": "tsx scripts/game-health-check.ts --apply",
    "audit:mobile": "tsx scripts/audit-mobile-gameplay.ts",
    "audit:thumbnails": "tsx scripts/audit-thumbnails.ts",
    "audit:thumbnails:apply": "tsx scripts/audit-thumbnails.ts -- --apply",
    "audit:ads": "tsx scripts/audit-ads-injection.ts",
    "audit:production": "node scripts/production-health-audit.mjs",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {},
  "devDependencies": {
    "@google/genai": "^2.9.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.20.0",
    "@types/passport": "^1.0.17",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "esbuild": "^0.25.12",
    "express": "^4.22.2",
    "express-session": "^1.19.0",
    "firebase": "^12.15.0",
    "lru-cache": "^11.5.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.40.0",
    "openid-client": "^6.8.4",
    "p-limit": "^7.3.0",
    "p-retry": "^8.0.0",
    "passport": "^0.7.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^6.4.3",
    "zod": "^4.4.3",
    "zod-validation-error": "^5.0.0"
  },
  "overrides": {},
  "engines": {
    "node": ">=20"
  }
}
